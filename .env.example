# Alchemy API（Optimismチェーンのトークンデータ取得）
# https://www.alchemy.com/ でアカウント作成 → Optimism Mainnet のAPIキーを取得
ALCHEMY_API_KEY=

# トークンコントラクトアドレス（Optimism上のERC-20）
# 成績トークン
ACHIEVEMENT_TOKEN_ADDRESS=
# 貢献トークン
CONTRIBUTION_TOKEN_ADDRESS=

# GitHub Personal Access Token（受講生リポのアクティビティ取得用）
# https://github.com/settings/tokens → Fine-grained token → public_repo read権限
GITHUB_TOKEN=

# NextAuth（SIWE認証用）
# openssl rand -base64 32 で生成
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# WalletConnect Project ID（RainbowKit用）
# https://cloud.walletconnect.com/ でプロジェクト作成
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optimism Chain ID（通常は変更不要）
NEXT_PUBLIC_CHAIN_ID=10
